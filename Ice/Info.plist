<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Auto-update disabled for this fork. Do NOT point at Ice's appcast/key,
	     or Barkeep would update itself into Ice. Barkeep will add its own feed +
	     Ed25519 key here if/when it hosts signed updates. -->
	<key>SUEnableAutomaticChecks</key>
	<false/>
	<key>SUFeedURL</key>
	<string>https://bozhenglong.github.io/Barkeep/appcast.xml</string>
</dict>
</plist>
